# Cagey Project — environment configuration
# Copy this file to `.env` and fill in your values.

# Required: your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude model (default: claude-opus-4-6)
# CAGEY_MODEL=claude-opus-4-6

# Optional: concurrent analysis requests (default: 5)
# CAGEY_CONCURRENCY=5

# Optional: max tokens per analysis call (default: 2048)
# CAGEY_MAX_TOKENS=2048

# Optional: where to write reports and charts (default: ./cagey_output)
# CAGEY_OUTPUT_DIR=./cagey_output
